      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');\n\n  :root {\n    --primary: #3b82f6;\n    --accent: #818cf8;\n    --canvas: #0b1326;\n    --surface-container: #060e20;\n    --glass-bg: rgba(19, 27, 46, 0.7);\n    --glass-border: rgba(255, 255, 255, 0.15);\n    --text-primary: #ffffff;\n    --text-secondary: #64748b;\n    --success: #10b981;\n  }\n\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    margin: 0;\n    padding: 0;\n    background: var(--surface-container);\n    color: var(--text-primary);\n    overflow: hidden;\n  }\n\n  .bg-dashboard {\n    position: fixed;\n    inset: 0;\n    background-image: url('https://images.pexels.com/photos/32026177/pexels-photo-32026177.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80');\n    background-size: cover;\n    background-position: center;\n    filter: blur(20px) brightness(0.4);\n    z-index: 0;\n  }\n\n  .overlay-dark {\n    position: fixed;\n    inset: 0;\n    background: rgba(6, 14, 32, 0.7);\n    z-index: 1;\n  }\n\n  .glass-modal {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    border-radius: 24px;\n    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);\n    width: 800px;\n    display: flex;\n    overflow: hidden;\n    position: relative;\n    z-index: 10;\n  }\n\n  .btn-gradient {\n    background: linear-gradient(135deg, var(--primary), var(--accent));\n    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .btn-gradient:hover {\n    transform: scale(1.02);\n  }\n\n  .input-field {\n    background: rgba(11, 19, 38, 0.8);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    transition: border-color 0.2s, box-shadow 0.2s;\n  }\n\n  .input-field:focus-within {\n    border-color: var(--primary);\n    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);\n  }\n\n  .strength-meter {\n    height: 2px;\n    width: 0;\n    transition: width 0.3s ease, background-color 0.3s ease;\n  }\n\n  .password-input:focus + .strength-meter {\n    width: 100%;\n    background: var(--success);\n  }\n</style>\n<div class=\"flex items-center justify-center min-h-screen\" data-kid=\"1\" data-name=\"modal layout container\">\n\n<div class=\"bg-dashboard\" data-kid=\"1-1\" data-name=\"background blur layer\"></div>\n<div class=\"overlay-dark\" data-kid=\"1-2\" data-name=\"screen dimming overlay\"></div>\n\n<div class=\"glass-modal\" data-kid=\"1-3\" data-name=\"authentication glass modal\">\n\n<div class=\"w-1/2 p-12 flex flex-col justify-between border-r border-(--glass-border) bg-white/5\" data-kid=\"1-3-1\" data-name=\"info column container\">\n<div data-kid=\"1-3-1-1\" data-name=\"modal header group\">\n<div class=\"w-12 h-12 bg-(--primary)/20 rounded-xl flex items-center justify-center mb-8 border border-(--primary)/30\" data-kid=\"1-3-1-1-1\" data-name=\"security icon container\">\n<i class=\"text-(--success) w-6 h-6\" data-dynamic=\"true\" data-kid=\"1-3-1-1-1-1\" data-lucide=\"shield-check\" data-name=\"shield check icon\" data-reason=\"rendered by lucide script\"></i>\n</div>\n<h2 class=\"text-3xl font-bold mb-4 tracking-tight\" data-kid=\"1-3-1-1-2\" data-name=\"modal title\">Secure Gateway</h2>\n<p class=\"text-(--text-secondary) text-sm leading-relaxed\" data-kid=\"1-3-1-1-3\" data-name=\"modal description text\">\n          Authorized personnel only. All access attempts are logged and monitored in real-time.\n        </p>\n</div>\n<div class=\"space-y-4\" data-kid=\"1-3-1-2\" data-name=\"system info group\">\n<div class=\"flex items-center gap-3 text-xs text-(--text-secondary)\" data-kid=\"1-3-1-2-1\" data-name=\"status indicator group\">\n<div class=\"w-1.5 h-1.5 rounded-full bg-(--success) animate-pulse\" data-kid=\"1-3-1-2-1-1\" data-name=\"pulse status dot\"></div>\n<span data-kid=\"1-3-1-2-1-2\" data-name=\"status label text\">System Status: Optimal</span>\n</div>\n<div class=\"text-[10px] text-(--text-secondary)/50 uppercase tracking-widest\" data-kid=\"1-3-1-2-2\" data-name=\"encryption info label\">\n          Encryption Level: AES-256-GCM\n        </div>\n</div>\n</div>\n\n<div class=\"w-1/2 p-12 bg-black/10\" data-kid=\"1-3-2\" data-name=\"form column container\">\n<div class=\"mb-8\" data-kid=\"1-3-2-1\" data-name=\"login section header\">\n<h3 class=\"text-xl font-semibold mb-1\" data-kid=\"1-3-2-1-1\" data-name=\"login section title\">Identity Verification</h3>\n<p class=\"text-sm text-(--text-secondary)\" data-kid=\"1-3-2-1-2\" data-name=\"login section subtitle\">Enter your enterprise credentials</p>\n</div>\n<form class=\"space-y-6\" data-kid=\"1-3-2-2\" data-name=\"login form\" onsubmit=\"event.preventDefault()\">\n\n<div data-kid=\"1-3-2-2-1\" data-name=\"email field group\">\n<label class=\"block text-xs font-medium text-(--text-secondary) mb-2 uppercase tracking-wider\" data-kid=\"1-3-2-2-1-1\" data-name=\"email label\">Email Address</label>\n<div class=\"input-field flex items-center px-4 py-3 rounded-lg\" data-kid=\"1-3-2-2-1-2\" data-name=\"email input container\">\n<i class=\"w-5 h-5 text-(--text-secondary) mr-3\" data-dynamic=\"true\" data-kid=\"1-3-2-2-1-2-1\" data-lucide=\"mail\" data-name=\"mail icon\" data-reason=\"rendered by lucide script\"></i>\n<input class=\"bg-transparent border-none outline-none text-sm w-full text-white placeholder:text-(--text-secondary)/50\" data-kid=\"1-3-2-2-1-2-2\" data-name=\"email input field\" placeholder=\"name@company.com\" type=\"email\">\n</div>\n</div>\n\n<div data-kid=\"1-3-2-2-2\" data-name=\"password field group\">\n<label class=\"block text-xs font-medium text-(--text-secondary) mb-2 uppercase tracking-wider\" data-kid=\"1-3-2-2-2-1\" data-name=\"password label\">Security Key</label>\n<div class=\"input-field flex items-center px-4 py-3 rounded-t-lg\" data-kid=\"1-3-2-2-2-2\" data-name=\"password input container\">\n<i class=\"w-5 h-5 text-(--text-secondary) mr-3\" data-dynamic=\"true\" data-kid=\"1-3-2-2-2-2-1\" data-lucide=\"lock\" data-name=\"lock icon\" data-reason=\"rendered by lucide script\"></i>\n<input class=\"password-input bg-transparent border-none outline-none text-sm w-full text-white placeholder:text-(--text-secondary)/50\" data-kid=\"1-3-2-2-2-2-2\" data-name=\"password input field\" placeholder=\"••••••••\" type=\"password\">\n</div>\n<div class=\"strength-meter\" data-kid=\"1-3-2-2-2-3\" data-name=\"password strength meter\"></div>\n</div>\n\n<button class=\"btn-gradient w-full py-3.5 rounded-lg font-semibold text-sm text-white shadow-lg shadow-blue-500/20\" data-kid=\"1-3-2-2-3\" data-name=\"verify identity button\">\n          Verify Identity\n        </button>\n</form>\n\n<div class=\"relative my-8\" data-kid=\"1-3-2-3\" data-name=\"divider container\">\n<div class=\"absolute inset-0 flex items-center\" data-kid=\"1-3-2-3-1\" data-name=\"horizontal line wrapper\"><div class=\"w-full border-t border-(--glass-border)\" data-kid=\"1-3-2-3-1-1\" data-name=\"horizontal line\"></div></div>\n<div class=\"relative flex justify-center text-xs\" data-kid=\"1-3-2-3-2\" data-name=\"or separator wrapper\"><span class=\"bg-transparent px-2 text-(--text-secondary) uppercase tracking-widest\" data-kid=\"1-3-2-3-2-1\" data-name=\"or separator text\">or</span></div>\n</div>\n\n<button class=\"w-full py-3 rounded-lg border border-(--glass-border) bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-center gap-2 text-sm font-medium text-white/70 hover:text-white\" data-kid=\"1-3-2-4\" data-name=\"hardware key button\">\n<i class=\"w-5 h-5\" data-dynamic=\"true\" data-kid=\"1-3-2-4-1\" data-lucide=\"usb\" data-name=\"usb icon\" data-reason=\"rendered by lucide script\"></i>\n        Use Hardware Security Key\n      </button>\n<div class=\"mt-8 text-center\" data-kid=\"1-3-2-5\" data-name=\"access request container\">\n<a class=\"text-xs text-(--text-secondary) hover:text-white transition-colors\" data-kid=\"1-3-2-5-1\" data-name=\"access request link\" href=\"#\">Request access from Administrator</a>\n</div>\n</div>\n</div>\n</div>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"2\"></script>\n<script data-kid=\"3\">\n  lucide.createIcons();\n</script>",

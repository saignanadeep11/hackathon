    "var_da7d1fe7cb36": {
      "type": "variant",
      "label": "Secure Gateway Overlay",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1440,
        "h": 800

      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: #3b82f6;\n    --accent: #818cf8;\n    --dark: #0b1326;\n    --dark-page: #060e20;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.1);\n    --text-slate: #64748b;\n    --emerald: #10b981;\n    --glass-blur: 12px;\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    color: white;\n    background-color: var(--dark-page);\n  }\n\n  .split-screen {\n    display: flex;\n    height: 100vh;\n    width: 100%;\n  }\n\n  .auth-column {\n    width: 40%;\n    min-width: 450px;\n    background-color: var(--dark-page);\n    display: flex;\n    flex-direction: column;\n    padding: 64px;\n    position: relative;\n    z-index: 10;\n  }\n\n  .visual-canvas {\n    flex: 1;\n    background-color: var(--dark);\n    position: relative;\n    overflow: hidden;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .bg-image {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    filter: blur(20px) brightness(0.4);\n    transform: scale(1.1);\n  }\n\n  .visual-overlay {\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle at center, transparent, rgba(6, 14, 32, 0.8));\n  }\n\n  .logo-lockup {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: auto;\n  }\n\n  .logo-icon {\n    width: 40px;\n    height: 40px;\n    background: rgba(59, 130, 246, 0.1);\n    border: 1px solid rgba(59, 130, 246, 0.3);\n    border-radius: 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--primary);\n    font-size: 20px;\n  }\n\n  .logo-text {\n    font-size: 24px;\n    font-weight: 700;\n    letter-spacing: -0.5px;\n  }\n\n  .form-container {\n    margin-top: auto;\n    margin-bottom: auto;\n    max-width: 400px;\n    width: 100%;\n  }\n\n  .greeting {\n    font-size: 30px;\n    font-weight: 600;\n    margin: 0 0 8px 0;\n  }\n\n  .subtitle {\n    color: var(--text-slate);\n    font-size: 14px;\n    margin-bottom: 40px;\n    line-height: 1.5;\n  }\n\n  .input-group {\n    margin-bottom: 24px;\n  }\n\n  .input-label {\n    display: block;\n    font-size: 13px;\n    font-weight: 500;\n    color: var(--text-slate);\n    margin-bottom: 8px;\n  }\n\n  .input-wrapper {\n    position: relative;\n    display: flex;\n    align-items: center;\n  }\n\n  .input-field {\n    width: 100%;\n    background: #131b2e;\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    border-radius: 8px;\n    padding: 12px 16px 12px 44px;\n    color: white;\n    font-family: inherit;\n    font-size: 14px;\n    transition: all 0.2s;\n  }\n\n  .input-field:focus {\n    outline: none;\n    border-color: var(--primary);\n    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);\n  }\n\n  .input-icon {\n    position: absolute;\n    left: 16px;\n    font-size: 18px;\n    color: var(--text-slate);\n  }\n\n  .login-btn {\n    width: 100%;\n    height: 48px;\n    background: linear-gradient(135deg, var(--primary), var(--accent));\n    border: none;\n    border-radius: 8px;\n    color: white;\n    font-weight: 600;\n    font-size: 14px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    cursor: pointer;\n    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n    margin-top: 32px;\n  }\n\n  .login-btn:hover {\n    transform: scale(1.02);\n  }\n\n  .status-footer {\n    margin-top: auto;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 12px;\n    color: var(--text-slate);\n  }\n\n  .status-dot {\n    width: 6px;\n    height: 6px;\n    background-color: var(--emerald);\n    border-radius: 50%;\n    box-shadow: 0 0 8px var(--emerald);\n    animation: pulse 2s infinite;\n  }\n\n  @keyframes pulse {\n    0% { opacity: 1; }\n    50% { opacity: 0.4; }\n    100% { opacity: 1; }\n  }\n\n  /* Right Side Glass Card */\n  .floating-card {\n    position: relative;\n    z-index: 5;\n    width: 500px;\n    background: var(--glass-bg);\n    backdrop-filter: blur(var(--glass-blur));\n    border: 1px solid var(--glass-border);\n    border-radius: 12px;\n    padding: 40px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);\n    transform: perspective(1000px) rotateY(-5deg) rotateX(2deg);\n  }\n\n  .card-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 32px;\n  }\n\n  .chart-area {\n    display: flex;\n    align-items: flex-end;\n    gap: 8px;\n    height: 120px;\n    margin-bottom: 24px;\n  }\n\n  .chart-bar {\n    flex: 1;\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 4px;\n    transition: height 1s ease-out;\n  }\n\n  .chart-bar.active {\n    background: linear-gradient(to top, var(--primary), var(--accent));\n  }\n\n  .pills-container {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n  }\n\n  .glass-pill {\n    position: absolute;\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(8px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    border-radius: 99px;\n    padding: 6px 12px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 11px;\n    font-weight: 500;\n  }\n\n  .pill-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n  }\n</style>\n<div class=\"split-screen\" data-kid=\"1\" data-name=\"split-screen page layout\">\n\n<div class=\"auth-column\" data-kid=\"1-1\" data-name=\"authentication column\">\n<div class=\"logo-lockup\" data-kid=\"1-1-1\" data-name=\"logo container\">\n<div class=\"logo-icon\" data-kid=\"1-1-1-1\" data-name=\"logo icon container\">\n<i class=\"ti ti-layers-union\" data-kid=\"1-1-1-1-1\" data-name=\"layers union icon\"></i>\n</div>\n<span class=\"logo-text\" data-kid=\"1-1-1-2\" data-name=\"logo text\">AssetFlow</span>\n</div>\n<div class=\"form-container\" data-kid=\"1-1-2\" data-name=\"form container\">\n<h1 class=\"greeting\" data-kid=\"1-1-2-1\" data-name=\"greeting headline\">Welcome back.</h1>\n<p class=\"subtitle\" data-kid=\"1-1-2-2\" data-name=\"subtitle text\">Enter your credentials to access the command center.</p>\n<form data-kid=\"1-1-2-3\" data-name=\"login form\" onsubmit=\"event.preventDefault()\">\n<div class=\"input-group\" data-kid=\"1-1-2-3-1\" data-name=\"email input group\">\n<label class=\"input-label\" data-kid=\"1-1-2-3-1-1\" data-name=\"email label\">Email Address</label>\n<div class=\"input-wrapper\" data-kid=\"1-1-2-3-1-2\" data-name=\"email input wrapper\">\n<i class=\"ti ti-mail input-icon\" data-kid=\"1-1-2-3-1-2-1\" data-name=\"mail icon\"></i>\n<input class=\"input-field\" data-kid=\"1-1-2-3-1-2-2\" data-name=\"email input field\" placeholder=\"name@company.com\" type=\"email\" value=\"admin@assetflow.ai\">\n</div>\n</div>\n<div class=\"input-group\" data-kid=\"1-1-2-3-2\" data-name=\"password input group\">\n<label class=\"input-label\" data-kid=\"1-1-2-3-2-1\" data-name=\"password label\">Password</label>\n<div class=\"input-wrapper\" data-kid=\"1-1-2-3-2-2\" data-name=\"password input wrapper\">\n<i class=\"ti ti-lock input-icon\" data-kid=\"1-1-2-3-2-2-1\" data-name=\"lock icon\"></i>\n<input class=\"input-field\" data-kid=\"1-1-2-3-2-2-2\" data-name=\"password input field\" placeholder=\"••••••••\" type=\"password\" value=\"password123\">\n</div>\n</div>\n<button class=\"login-btn\" data-kid=\"1-1-2-3-3\" data-name=\"submit login button\" type=\"submit\">\n          Access Command Center\n          <i class=\"ti ti-arrow-right\" data-kid=\"1-1-2-3-3-1\" data-name=\"arrow right icon\"></i>\n</button>\n</form>\n</div>\n<div class=\"status-footer\" data-kid=\"1-1-3\" data-name=\"system status footer\">\n<div class=\"status-dot\" data-kid=\"1-1-3-1\" data-name=\"pulsing status dot\"></div>\n<span data-kid=\"1-1-3-2\" data-name=\"system status text\">System Status: Online</span>\n</div>\n</div>\n\n<div class=\"visual-canvas\" data-kid=\"1-2\" data-name=\"visual canvas section\">\n<img alt=\"Brett Sayles on Pexels\" class=\"bg-image\" data-kid=\"1-2-1\" data-name=\"background image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4486718/pexels-photo-4486718.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=1440&amp;q=80\">\n<div class=\"visual-overlay\" data-kid=\"1-2-2\" data-name=\"visual overlay gradient\"></div>\n\n<div class=\"floating-card\" data-kid=\"1-2-3\" data-name=\"floating 3d glass card\">\n<div class=\"card-header\" data-kid=\"1-2-3-1\" data-name=\"card header\">\n<div data-kid=\"1-2-3-1-1\" data-name=\"card title text\" style=\"font-size: 14px; font-weight: 600;\">Asset Distribution</div>\n<div data-kid=\"1-2-3-1-2\" data-name=\"card status text\" style=\"font-size: 12px; color: var(--text-slate);\">Real-time</div>\n</div>\n<div class=\"chart-area\" data-kid=\"1-2-3-2\" data-name=\"chart container\">\n<div class=\"chart-bar\" data-kid=\"1-2-3-2-1\" data-name=\"inactive chart bar\" style=\"height: 40%;\"></div>\n<div class=\"chart-bar active\" data-kid=\"1-2-3-2-2\" data-name=\"active chart bar\" style=\"height: 80%;\"></div>\n<div class=\"chart-bar\" data-kid=\"1-2-3-2-3\" data-name=\"inactive chart bar\" style=\"height: 60%;\"></div>\n<div class=\"chart-bar active\" data-kid=\"1-2-3-2-4\" data-name=\"active chart bar\" style=\"height: 90%;\"></div>\n<div class=\"chart-bar\" data-kid=\"1-2-3-2-5\" data-name=\"inactive chart bar\" style=\"height: 50%;\"></div>\n<div class=\"chart-bar\" data-kid=\"1-2-3-2-6\" data-name=\"inactive chart bar\" style=\"height: 70%;\"></div>\n<div class=\"chart-bar active\" data-kid=\"1-2-3-2-7\" data-name=\"active chart bar\" style=\"height: 85%;\"></div>\n</div>\n<div data-kid=\"1-2-3-3\" data-name=\"card stats container\" style=\"display: flex; gap: 16px;\">\n<div data-kid=\"1-2-3-3-1\" data-name=\"active assets stat container\" style=\"flex: 1;\">\n<div data-kid=\"1-2-3-3-1-1\" data-name=\"active assets label\" style=\"font-size: 11px; color: var(--text-slate); margin-bottom: 4px;\">Active Assets</div>\n<div data-kid=\"1-2-3-3-1-2\" data-name=\"active assets value\" style=\"font-size: 18px; font-weight: 700;\">12,402</div>\n</div>\n<div data-kid=\"1-2-3-3-2\" data-name=\"uptime stat container\" style=\"flex: 1;\">\n<div data-kid=\"1-2-3-3-2-1\" data-name=\"uptime label\" style=\"font-size: 11px; color: var(--text-slate); margin-bottom: 4px;\">Uptime</div>\n<div data-kid=\"1-2-3-3-2-2\" data-name=\"uptime value\" style=\"font-size: 18px; font-weight: 700;\">99.98%</div>\n</div>\n</div>\n</div>\n\n<div class=\"pills-container\" data-kid=\"1-2-4\" data-name=\"floating pills container\">\n<div class=\"glass-pill\" data-kid=\"1-2-4-1\" data-name=\"system optimal pill\" style=\"top: 20%; left: 10%;\">\n<div class=\"pill-dot\" data-kid=\"1-2-4-1-1\" data-name=\"pill dot\" style=\"background-color: var(--emerald); box-shadow: 0 0 6px var(--emerald);\"></div>\n        System Optimal\n      </div>\n<div class=\"glass-pill\" data-kid=\"1-2-4-2\" data-name=\"syncing assets pill\" style=\"bottom: 15%; right: 12%;\">\n<div class=\"pill-dot\" data-kid=\"1-2-4-2-1\" data-name=\"pill dot\" style=\"background-color: var(--primary); box-shadow: 0 0 6px var(--primary);\"></div>\n        Syncing 243 assets\n      </div>\n</div>\n</div>\n</div>",
